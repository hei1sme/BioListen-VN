# Environment Variables Template
# Copy file này thành .env và điền vào

# ── LLM Providers ──────────────────────────────
# Groq — MIỄN PHÍ, siêu nhanh (llama-3.1, gemma2) — BẮT BUỘC có
GROQ_API_KEY=your_groq_key_here

# OpenAI (optional — nếu cần GPT-4o)
OPENAI_API_KEY=

# Anthropic — Claude (optional)
ANTHROPIC_API_KEY=

# Google Gemini (optional)
GOOGLE_API_KEY=

# ── Database ────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# ── App ─────────────────────────────────────────
DEBUG=true
SECRET_KEY=vaic2026-super-secret-change-me
