# Gitignore — VAIC 2026

# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.so
.venv/
env/
venv/

# Environment
.env
*.env.local

# PyTorch model files (too large for git — use Git LFS if needed)
backend/models/*.pt
backend/models/*.pth
backend/models/*.bin
*.safetensors

# Next.js
frontend/.next/
frontend/node_modules/
frontend/out/
frontend/.vercel

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Data & Datasets (nếu có sensitive data)
data/
*.csv
!docs/*.csv

# Models & Checkpoints (too large for git)
models/
BioListen_AI_Collaboration_Log.zip
Nhat_ky_cong_tac_AI.md
*.onnx

# Local Storage Cache
backend/local_storage/

